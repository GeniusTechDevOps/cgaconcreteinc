---
interface PageData {
    slug: string;
    title: string;
    description: string;
    city: string;
    state: string;
    serviceName?: string;
    proofs?: string[];
    contractor?: {
        name?: string;
        phone?: string;
        yearsInBusiness?: number;
    };
    service?: {
        category?: string;
        residential?: boolean;
        commercial?: boolean;
    };
}

interface Props {
    featuredPage?: PageData;
    secondaryPages: PageData[];
    companyName: string;
    fallbackPhone?: string;
}

const { featuredPage, secondaryPages, companyName, fallbackPhone } =
    Astro.props as Props;
---

<div class="mt-10 space-y-8">
    {featuredPage && (
        <a href={`/resources/${featuredPage.slug}`} class="group grid overflow-hidden rounded-[2.5rem] border border-black/10 bg-white shadow-[0_28px_90px_rgba(15,23,42,0.12)] transition-all duration-300 hover:-translate-y-1 hover:shadow-[0_40px_120px_rgba(15,23,42,0.16)] lg:grid-cols-[1.1fr_0.9fr]">
            <div class="relative overflow-hidden border-b border-black/8 bg-[linear-gradient(135deg,color-mix(in_srgb,var(--primary)_14%,white_86%),color-mix(in_srgb,var(--btn-color)_12%,white_88%)_58%,color-mix(in_srgb,var(--secondary)_10%,white_90%))] p-7 md:border-b-0 md:border-r md:p-8">
                <div class="absolute inset-0 bg-[radial-gradient(circle_at_top_right,rgba(255,255,255,0.7),transparent_28%),radial-gradient(circle_at_bottom_left,rgba(255,255,255,0.35),transparent_32%)]" aria-hidden="true"></div>
                <div class="relative">
                    <div class="flex flex-wrap items-center justify-between gap-3">
                        <span class="inline-flex items-center gap-2 rounded-full border px-4 py-2 text-[11px] font-black uppercase tracking-[0.2em] text-title" style={{ background: "color-mix(in srgb, var(--primary) 12%, white 88%)", borderColor: "color-mix(in srgb, var(--primary) 22%, transparent)" }}><i class="fa-solid fa-star-sharp-half-stroke text-primary" aria-hidden="true"></i>Spotlight entry</span>
                        <span class="inline-flex items-center gap-2 rounded-full border px-4 py-2 text-[11px] font-semibold uppercase tracking-[0.18em] text-title" style={{ background: "rgba(255,255,255,0.72)", borderColor: "rgba(15,23,42,0.08)" }}><i class="fa-solid fa-location-dot text-primary" aria-hidden="true"></i>{featuredPage.city}, {featuredPage.state}</span>
                    </div>
                    <h2 class="mt-6 max-w-4xl text-3xl font-black leading-tight tracking-[-0.03em] text-title md:text-5xl">{featuredPage.title}</h2>
                    <p class="mt-5 max-w-3xl text-base leading-8 text-text/84">{featuredPage.description}</p>
                    <div class="mt-6 flex flex-wrap gap-2">
                        {featuredPage.serviceName && <span class="inline-flex items-center rounded-full border px-4 py-2 text-sm font-semibold text-title" style={{ background: "rgba(255,255,255,0.78)", borderColor: "rgba(15,23,42,0.08)" }}>{featuredPage.serviceName}</span>}
                        {featuredPage.contractor?.yearsInBusiness && <span class="inline-flex items-center rounded-full border px-4 py-2 text-sm font-semibold text-title" style={{ background: "rgba(255,255,255,0.78)", borderColor: "rgba(15,23,42,0.08)" }}>{featuredPage.contractor.yearsInBusiness}+ years experience</span>}
                    </div>
                </div>
            </div>
            <div class="grid gap-4 p-7 md:p-8">
                <div class="grid gap-4 sm:grid-cols-2">
                    <div class="rounded-[1.5rem] border border-black/10 bg-neutral-50 p-4"><p class="text-[11px] uppercase tracking-[0.18em] text-text/52">Contractor</p><p class="mt-2 text-base font-black text-title">{featuredPage.contractor?.name || companyName}</p></div>
                    <div class="rounded-[1.5rem] border border-black/10 bg-neutral-50 p-4"><p class="text-[11px] uppercase tracking-[0.18em] text-text/52">Category</p><p class="mt-2 text-base font-black text-title">{featuredPage.service?.category || "Local Service"}</p></div>
                    <div class="rounded-[1.5rem] border border-black/10 bg-neutral-50 p-4"><p class="text-[11px] uppercase tracking-[0.18em] text-text/52">Audience</p><p class="mt-2 text-base font-black text-title">{[featuredPage.service?.residential ? "Residential" : "", featuredPage.service?.commercial ? "Commercial" : ""].filter(Boolean).join(" & ") || "General"}</p></div>
                    <div class="rounded-[1.5rem] border border-black/10 bg-neutral-50 p-4"><p class="text-[11px] uppercase tracking-[0.18em] text-text/52">Direct line</p><p class="mt-2 text-base font-black text-title">{featuredPage.contractor?.phone || fallbackPhone || "Call for details"}</p></div>
                </div>
                <div class="rounded-[1.75rem] border border-black/10 bg-[linear-gradient(180deg,rgba(248,248,248,0.95),rgba(255,255,255,1))] p-5">
                    <p class="text-[11px] font-black uppercase tracking-[0.18em] text-text/52">Quick facts</p>
                    <div class="mt-3 flex flex-wrap gap-2">
                        {featuredPage.proofs?.slice(0, 3).map((proof) => (
                            <span class="inline-flex items-center rounded-full border border-black/10 bg-white px-3 py-2 text-xs font-semibold text-text/84"><i class="fa-solid fa-check mr-2 text-[10px] text-primary" aria-hidden="true"></i>{proof}</span>
                        ))}
                    </div>
                </div>
                <div class="inline-flex items-center gap-2 text-sm font-black uppercase tracking-[0.14em] text-primary transition-transform duration-300 group-hover:translate-x-1">Open featured resource<i class="fa-solid fa-arrow-right text-xs" aria-hidden="true"></i></div>
            </div>
        </a>
    )}

    <div class="grid gap-6 xl:grid-cols-[0.9fr_1.1fr]">
        <div class="rounded-[2rem] border border-black/10 bg-white p-6 shadow-[0_18px_60px_rgba(15,23,42,0.08)]">
            <div class="flex items-center justify-between gap-3">
                <div><p class="text-[11px] font-black uppercase tracking-[0.18em] text-text/52">Priority cards</p><h3 class="mt-2 text-2xl font-black text-title">Next best resources</h3></div>
                <span class="rounded-full bg-primary/10 px-3 py-1 text-[11px] font-black uppercase tracking-[0.18em] text-primary">{secondaryPages.slice(0, 2).length} items</span>
            </div>
            <div class="mt-6 space-y-4">
                {secondaryPages.slice(0, 2).map((page) => (
                    <a href={`/resources/${page.slug}`} class="group block rounded-[1.75rem] border border-black/10 bg-neutral-50 p-5 transition-all duration-300 hover:border-primary/40 hover:bg-white hover:shadow-[0_18px_50px_rgba(15,23,42,0.08)]">
                        <div class="flex flex-wrap items-start justify-between gap-3">
                            <span class="inline-flex items-center gap-2 rounded-full bg-white px-3 py-1 text-[11px] font-semibold uppercase tracking-[0.18em] text-text/70"><i class="fa-solid fa-location-dot text-primary" aria-hidden="true"></i>{page.city}, {page.state}</span>
                            <span class="text-[11px] font-black uppercase tracking-[0.16em] text-primary">Priority</span>
                        </div>
                        <h2 class="mt-4 text-2xl font-black leading-tight text-title transition-colors group-hover:text-primary">{page.title}</h2>
                        <p class="mt-3 line-clamp-3 text-sm leading-7 text-text/82">{page.description}</p>
                        <div class="mt-4 flex items-center justify-between gap-4">
                            <span class="inline-flex items-center rounded-full border border-primary/20 bg-primary/8 px-3 py-1 text-xs font-semibold text-primary">{page.serviceName || "Local resource"}</span>
                            <span class="inline-flex items-center gap-2 text-sm font-black text-primary transition-transform duration-300 group-hover:translate-x-1">View<i class="fa-solid fa-arrow-right text-xs" aria-hidden="true"></i></span>
                        </div>
                    </a>
                ))}
            </div>
        </div>

        {secondaryPages.length > 2 && (
            <div class="rounded-[2rem] border border-black/10 bg-white p-6 shadow-[0_18px_60px_rgba(15,23,42,0.08)]">
                <div class="flex items-center justify-between gap-3">
                    <div><p class="text-[11px] font-black uppercase tracking-[0.18em] text-text/52">Resource archive</p><h3 class="mt-2 text-2xl font-black text-title">More published entries</h3></div>
                    <span class="rounded-full border px-3 py-1 text-[11px] font-black uppercase tracking-[0.16em] text-title" style={{ background: "color-mix(in srgb, var(--secondary) 10%, white 90%)", borderColor: "color-mix(in srgb, var(--secondary) 20%, transparent)" }}>{secondaryPages.slice(2).length} resources</span>
                </div>
                <div class="mt-6 grid grid-cols-1 gap-4 md:grid-cols-2">
                    {secondaryPages.slice(2).map((page) => (
                        <a href={`/resources/${page.slug}`} class="group rounded-[1.6rem] border border-black/10 bg-[linear-gradient(180deg,#fff,#fafafa)] p-5 transition-all duration-300 hover:-translate-y-1 hover:border-primary/40 hover:shadow-[0_18px_50px_rgba(15,23,42,0.08)]">
                            <div class="flex items-center justify-between gap-3">
                                <span class="text-[11px] font-semibold uppercase tracking-[0.16em] text-text/58">{page.city}, {page.state}</span>
                                <span class="inline-flex h-9 w-9 items-center justify-center rounded-full bg-primary/10 text-primary"><i class="fa-solid fa-arrow-up-right" aria-hidden="true"></i></span>
                            </div>
                            <h2 class="mt-4 text-xl font-black leading-tight text-title transition-colors group-hover:text-primary">{page.title}</h2>
                            <p class="mt-3 line-clamp-3 text-sm leading-7 text-text/82">{page.description}</p>
                            <div class="mt-4 flex flex-wrap gap-2">
                                <span class="inline-flex items-center rounded-full bg-neutral-100 px-3 py-1 text-xs font-semibold text-text/74">{page.serviceName || "Local resource"}</span>
                            </div>
                        </a>
                    ))}
                </div>
            </div>
        )}
    </div>
</div>
